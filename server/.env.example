# FormFlow Server Environment Configuration
# Copy this file to .env and fill in your values.

# Server
PORT=5000

# Database
DATABASE_URL=sqlite+aiosqlite:///./formflow.db

# OpenAI API Key (required for AI formation generation)
OPENAI_API_KEY=your-key-here

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
